<% report_title = @form_label ? @form_label : "各種代理奉納（合計）" %>
<% content_for :title, "帳票: #{report_title}" %>

<section class="page-head">
  <div>
    <h2>帳票: <%= report_title %></h2>
    <p class="section-lead">伝道会ごとの入金済み本数、未入金本数、合計本数を表示します。</p>
  </div>
</section>

<section class="card">
  <div class="counts-sheet-grid">
    <section>
      <table class="report-table report-table-compact">
        <thead>
          <tr>
            <th>伝道会</th>
            <th class="text-right">入金済み本数</th>
            <th class="text-right">未入金本数</th>
            <th class="text-right">合計本数</th>
          </tr>
        </thead>
        <tbody>
          <% @left_rows.each do |row| %>
            <% if row[:is_blank] %>
              <tr class="blank-row"><td colspan="4">&nbsp;</td></tr>
            <% else %>
              <tr>
                <td>
                  <% unless row[:code].to_s.start_with?("99") || row[:code] == "9000" %>
                    <%= row[:code] %><br>
                  <% end %>
                  <%= row[:name].html_safe %>
                </td>
                <td class="text-right"><%= row[:paid_count] %></td>
                <td class="text-right <%= row[:unpaid_count].positive? ? "status-unpaid" : "" %>"><%= row[:unpaid_count] %></td>
                <td class="text-right"><%= row[:total_count] %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </section>
    <section>
      <table class="report-table report-table-compact">
        <thead>
          <tr>
            <th>伝道会</th>
            <th class="text-right">入金済み本数</th>
            <th class="text-right">未入金本数</th>
            <th class="text-right">合計本数</th>
          </tr>
        </thead>
        <tbody>
          <% @right_rows.each do |row| %>
            <% if row[:is_blank] %>
              <tr class="blank-row"><td colspan="4">&nbsp;</td></tr>
            <% else %>
              <tr>
                <td>
                  <% unless row[:code].to_s.start_with?("99") || row[:code] == "9000" %>
                    <%= row[:code] %><br>
                  <% end %>
                  <%= row[:name].html_safe %>
                </td>
                <td class="text-right"><%= row[:paid_count] %></td>
                <td class="text-right <%= row[:unpaid_count].positive? ? "status-unpaid" : "" %>"><%= row[:unpaid_count] %></td>
                <td class="text-right"><%= row[:total_count] %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </section>
  </div>
</section>
