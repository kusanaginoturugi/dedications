<% content_for :title, "サインイン" %>

<section class="card narrow-card">
  <h2>サインイン</h2>
  <p class="section-lead">注文入力はサインイン済みユーザーのみ利用できます。</p>

  <%= form_with url: session_path, class: "stack-form" do |form| %>
    <div class="field">
      <%= form.label :email, "メールアドレス" %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="field">
      <%= form.label :password, "パスワード" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password" %>
    </div>

    <%= form.submit "サインイン", class: "primary-button" %>
  <% end %>
</section>
