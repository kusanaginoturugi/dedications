<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "八大明王護摩供代理奉納" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body>
    <div class="app-shell">
      <header class="app-header">
        <div>
          <h1>八大明王護摩供代理奉納</h1>
        </div>
        <% if signed_in? %>
          <nav class="header-nav">
            <details class="menu-tree">
              <summary class="secondary-link">メニュー</summary>
              <div class="menu-tree-panel">
                <section>
                  <h3>注文</h3>
                  <%= link_to "注文一覧", orders_path %>
                  <%= link_to "FAX注文入力", new_order_path %>
                </section>
                <section>
                  <h3>集計</h3>
                  <%= link_to "注文集計", summary_orders_path %>
                  <%= link_to "個別集計", personal_summary_orders_path %>
                </section>
                <section>
                  <h3>帳票</h3>
                  <%= link_to "前夜祭・当日", pre_event_reports_path %>
                  <%= link_to "代理・在庫", proxy_inventory_reports_path %>
                  <%= link_to "各種代理奉納", dedication_counts_reports_path %>
                </section>
                <% if current_user.is_admin? %>
                  <section>
                    <h3>管理</h3>
                    <%= link_to "ユーザー一覧", users_path %>
                    <%= link_to "ユーザー追加", new_user_path %>
                  </section>
                <% end %>
              </div>
            </details>
            <%= button_to "サインアウト", session_path, method: :delete, class: "ghost-button" %>
          </nav>
        <% end %>
      </header>

      <% flash.each do |type, message| %>
        <p class="flash <%= type %>"><%= message %></p>
      <% end %>

      <main>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
