<% content_for :title, "個別集計" %>

<section class="page-head">
  <div>
    <h2>個別集計</h2>
    <p class="section-lead">入力者ごとの実績と、申込明細を時系列で確認します。</p>
  </div>
</section>

<section class="card">
  <% if @orders.any? %>
    <section class="personal-summary-overview">
      <% @user_summaries.each do |summary| %>
        <article class="summary-total-card personal-summary-card text-right">
          <h3 style="text-align: left;"><%= summary[:user].display_name %></h3>
          <p><span>件数</span><strong><%= summary[:order_count] %>件</strong></p>
          <p><span>金額</span><strong><%= number_to_currency(summary[:total_amount], unit: "¥", precision: 0) %></strong></p>
          <p><span>未入金</span><strong class="<%= summary[:unpaid_count].positive? ? "status-unpaid" : "" %>"><%= summary[:unpaid_count] %>件</strong></p>
        </article>
      <% end %>
    </section>

    <div class="table-wrap">
      <table class="stack-on-mobile personal-summary-table">
        <thead>
          <tr>
            <th><%= link_to "番号#{sort_arrow('page_number')}", url_for(sort: 'page_number', direction: next_direction('page_number')), class: "sort-link" %></th>
            <th><%= link_to "奉納者名#{sort_arrow('offerer_name')}", url_for(sort: 'offerer_name', direction: next_direction('offerer_name')), class: "sort-link" %></th>
            <th><%= link_to "入力日#{sort_arrow('created_at')}", url_for(sort: 'created_at', direction: next_direction('created_at')), class: "sort-link" %></th>
            <th><%= link_to "FAX受信日#{sort_arrow('fax_received_on')}", url_for(sort: 'fax_received_on', direction: next_direction('fax_received_on')), class: "sort-link" %></th>
            <th><%= link_to "種類#{sort_arrow('form_type')}", url_for(sort: 'form_type', direction: next_direction('form_type')), class: "sort-link" %></th>
            <th>本数</th>
            <th>金額</th>
            <th><%= link_to "入金状態#{sort_arrow('paid')}", url_for(sort: 'paid', direction: next_direction('paid')), class: "sort-link" %></th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr class="clickable-row" data-href="<%= edit_order_path(order) %>" tabindex="0" role="link" aria-label="ページ <%= order.page_number %> の申込を編集">
              <td data-label="番号"><%= order.page_number %></td>
              <td data-label="奉納者名"><%= order.offerer_name.presence || "-" %></td>
              <td data-label="入力日"><%= l(order.created_at.to_date) %></td>
              <td data-label="FAX受信日"><%= order.fax_received_on ? l(order.fax_received_on) : "-" %></td>
              <td data-label="種類"><%= order.form_label.html_safe %></td>
              <td data-label="本数"><%= order.total_quantity.present? ? "#{order.total_quantity} 本" : "-" %></td>
              <td data-label="金額"><%= order.total_amount.present? ? number_to_currency(order.total_amount, unit: "¥", precision: 0) : "-" %></td>
              <td data-label="入金状態">
                <span class="<%= order.paid? ? "status-paid" : "status-unpaid" %>"><%= order.paid? ? "入金済み" : "未入金" %></span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p>まだ申込は登録されていません。</p>
  <% end %>
</section>

