<% content_for :title, "申込一覧" %>

<section class="page-head">
  <div>
    <h2>申込一覧</h2>
    <p class="section-lead">FAX 1枚ごとに登録した申込の一覧です。</p>
  </div>
</section>

<section class="card">
  <% if @orders.any? %>
    <% grouped_orders = Order::FORM_DEFINITIONS.keys.each_with_object([]) do |form_type, groups|
      matches = @orders.select { |order| order.form_type == form_type }
      next if matches.empty?

      groups << [ Order.form_definition_for(form_type).fetch(:label), matches ]
    end %>

    <% grouped_orders.each do |label, orders| %>
      <section class="order-group">
        <header class="order-group-header">
          <h3><%= label %></h3>
          <p><%= orders.size %>件</p>
        </header>

        <div class="summary-totals">
          <div class="summary-total-card">
            <span class="summary-total-label">合計本数</span>
            <strong><%= orders.sum { |order| order.total_quantity.to_i } %></strong>
          </div>
          <div class="summary-total-card">
            <span class="summary-total-label">合計金額</span>
            <strong><%= number_to_currency(orders.sum { |order| order.total_amount.to_i }, unit: "¥", precision: 0) %></strong>
          </div>
        </div>

        <div class="table-wrap">
          <table class="stack-on-mobile orders-table">
            <colgroup>
              <col class="orders-page-column">
              <col class="orders-date-column">
              <col>
              <col class="orders-quantity-column">
              <col class="orders-amount-column">
              <col>
              <col>
            </colgroup>
            <thead>
              <tr>
                <th><%= link_to "ページ#{sort_arrow('page_number')}", url_for(sort: 'page_number', direction: next_direction('page_number')), class: "sort-link" %></th>
                <th>受信日</th>
                <th>伝道会名</th>
                <th class="text-right">本数</th>
                <th class="text-right">金額</th>
                <th>入金状態</th>
                <th>入力者</th>
              </tr>
              </thead>
              <tbody>
              <% orders.each do |order| %>
                <tr class="clickable-row" data-href="<%= edit_order_path(order) %>" tabindex="0" role="link" aria-label="ページ <%= order.page_number %> の申込を編集">
                  <td data-label="ページ"><%= order.page_number %></td>
                  <td data-label="受信日"><%= order.fax_received_on ? l(order.fax_received_on) : "-" %></td>
                  <td data-label="伝道会名"><%= "#{order.congregation.code} #{order.congregation.name}" %></td>
                  <td data-label="本数" class="text-right"><%= order.total_quantity.present? ? "#{order.total_quantity} 本" : "-" %></td>
                  <td data-label="金額" class="text-right"><%= order.total_amount.present? ? number_to_currency(order.total_amount, unit: "¥", precision: 0) : "-" %></td>
                  <td data-label="入金状態">
                    <span class="<%= order.paid? ? "status-paid" : "status-unpaid" %>"><%= order.paid? ? "入金済み" : "未入金" %></span>
                  </td>
                  <td data-label="入力者"><%= order.user.display_name %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>
  <% else %>
    <p>まだ注文は登録されていません。</p>
  <% end %>
</section>
