<% content_for :title, "処理状況" %>

<section class="page-head">
  <div>
    <h2>処理状況</h2>
    <p class="section-lead">申込書種類ごとに処理状況を確認します。</p>
  </div>
</section>

<section class="card">
  <% if @order_groups.any? %>
    <% @order_groups.each do |label, orders| %>
      <section class="order-group">
        <header class="order-group-header">
          <h3><%= label.html_safe %></h3>
          <p><%= orders.size %>件</p>
        </header>

        <div class="table-wrap">
          <table class="stack-on-mobile orders-table processing-status-table">
            <colgroup>
              <col class="orders-page-column">
              <col class="orders-offerer-column">
              <col class="orders-congregation-column">
              <col class="orders-date-column">
              <col class="orders-date-column">
              <col class="orders-type-column">
              <col class="orders-serial-column">
              <col class="orders-quantity-column">
              <col class="orders-amount-column">
              <col class="orders-status-column">
              <col class="orders-date-column">
            </colgroup>
            <thead>
              <tr>
                <th><%= link_to "番号#{sort_arrow('page_number')}", url_for(sort: 'page_number', direction: next_direction('page_number')), class: sort_link_class('page_number') %></th>
                <th><%= link_to "奉納者名#{sort_arrow('offerer_name')}", url_for(sort: 'offerer_name', direction: next_direction('offerer_name')), class: sort_link_class('offerer_name') %></th>
                <th>伝道会名</th>
                <th><%= link_to "FAX受信日#{sort_arrow('fax_received_on')}", url_for(sort: 'fax_received_on', direction: next_direction('fax_received_on')), class: sort_link_class('fax_received_on') %></th>
                <th><%= link_to "奉納日#{sort_arrow('dedication_on')}", url_for(sort: 'dedication_on', direction: next_direction('dedication_on')), class: sort_link_class('dedication_on') %></th>
                <th><%= link_to "種類#{sort_arrow('form_type')}", url_for(sort: 'form_type', direction: next_direction('form_type')), class: sort_link_class('form_type') %></th>
                <th class="text-right">通し番号</th>
                <th class="text-right">本数</th>
                <th class="text-right">金額</th>
                <th><%= link_to "入金状態#{sort_arrow('paid')}", url_for(sort: 'paid', direction: next_direction('paid')), class: sort_link_class('paid') %></th>
                <th><%= link_to "入力日#{sort_arrow('created_at')}", url_for(sort: 'created_at', direction: next_direction('created_at')), class: sort_link_class('created_at') %></th>
              </tr>
            </thead>
            <tbody>
              <% orders.each do |order| %>
                <tr class="clickable-row" data-href="<%= edit_order_path(order) %>" tabindex="0" role="link" aria-label="番号 <%= order.page_number %> の申込を編集">
                  <td data-label="番号"><%= order.page_number %></td>
                  <td data-label="奉納者名"><%= order.offerer_name.presence || "-" %></td>
                  <td data-label="伝道会名"><%= order.congregation.name %></td>
                  <td data-label="FAX受信日"><%= order.fax_received_on ? l(order.fax_received_on) : "-" %></td>
                  <td data-label="奉納日"><%= order.dedication_on ? l(order.dedication_on) : "-" %></td>
                  <td data-label="種類"><%= order.form_label.html_safe %></td>
                  <td data-label="通し番号" class="text-right"><%= order.serial_number_range_label || "-" %></td>
                  <td data-label="本数" class="text-right"><%= order.total_quantity.present? ? "#{order.total_quantity} 本" : "-" %></td>
                  <td data-label="金額" class="text-right"><%= order.total_amount.present? ? number_to_currency(order.total_amount, unit: "¥", precision: 0) : "-" %></td>
                  <td data-label="入金状態">
                    <span class="<%= order.paid? ? "status-paid" : "status-unpaid" %>"><%= order.paid? ? "入金済み" : "未入金" %></span>
                  </td>
                  <td data-label="入力日"><%= l(order.created_at.to_date) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>
  <% else %>
    <p>まだ申込は登録されていません。</p>
  <% end %>
</section>
