<% content_for :title, "注文詳細" %>

<section class="page-head">
  <div>
    <h2>注文詳細</h2>
    <p class="section-lead">FAX 1枚分の入力内容です。</p>
  </div>
  <%= link_to "一覧へ戻る", orders_path, class: "secondary-link" %>
</section>

<section class="card">
  <dl class="detail-grid">
    <div>
      <dt>ページ番号</dt>
      <dd><%= @order.page_number %></dd>
    </div>
    <div>
      <dt>注文書種類</dt>
      <dd><%= @order.form_label %></dd>
    </div>
    <div>
      <dt>伝道会</dt>
      <dd><%= "#{@order.congregation.code} #{@order.congregation.name}" %></dd>
    </div>
    <div>
      <dt>入金状態</dt>
      <dd><%= @order.paid? ? "入金済" : "未入金" %></dd>
    </div>
    <div>
      <dt>担当者</dt>
      <dd><%= @order.contact_name.presence || "未入力" %></dd>
    </div>
    <div>
      <dt>電話</dt>
      <dd><%= @order.phone.presence || "未入力" %></dd>
    </div>
  </dl>

  <div class="table-wrap">
    <table class="stack-on-mobile">
      <thead>
        <tr>
          <th>奉納者氏名</th>
          <th>願事</th>
          <th>本数</th>
          <th>番号</th>
        </tr>
      </thead>
      <tbody>
        <% @order.order_items.each do |item| %>
          <% next unless item.filled_row? %>
          <tr>
            <td data-label="奉納者氏名"><%= item.donor_name %></td>
            <td data-label="願事"><%= item.wish.presence || "-" %></td>
            <td data-label="本数"><%= item.quantity %> 本</td>
            <td data-label="番号"><%= item.entry_number.presence || "-" %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <th colspan="3">ページ合計</th>
          <th><%= @order.page_total_quantity %> 本 / <%= number_to_currency(@order.page_total_amount, unit: "¥", precision: 0) %></th>
        </tr>
      </tfoot>
    </table>
  </div>
</section>
