<% content_for :title, "注文詳細" %>

<section class="page-head">
  <div>
    <h2>注文詳細</h2>
    <p class="section-lead">FAX 1枚分の入力内容です。</p>
  </div>
  <%= link_to "一覧へ戻る", orders_path, class: "secondary-link" %>
</section>

<section class="card">
  <dl class="detail-grid">
    <div>
      <dt>ページ番号</dt>
      <dd><%= @order.page_number %></dd>
    </div>
    <div>
      <dt>注文書種類</dt>
      <dd><%= @order.form_label %></dd>
    </div>
    <div>
      <dt>ファックス受信日</dt>
      <dd><%= @order.fax_received_on&.strftime("%Y-%m-%d") || "未入力" %></dd>
    </div>
    <div>
      <dt>伝道会</dt>
      <dd><%= "#{@order.congregation.code} #{@order.congregation.name}" %></dd>
    </div>
    <div>
      <dt>入金状態</dt>
      <dd><%= @order.paid? ? "入金済" : "未入金" %></dd>
    </div>
    <div>
      <dt>通し番号(開始)</dt>
      <dd><%= @order.serial_number_start.presence || "未入力" %></dd>
    </div>
    <div>
      <dt>通し番号(終了)</dt>
      <dd><%= @order.serial_number_end.presence || "未入力" %></dd>
    </div>
    <div>
      <dt>本数</dt>
      <dd><%= @order.total_quantity.present? ? "#{@order.total_quantity} 本" : "未計算" %></dd>
    </div>
    <div>
      <dt>金額</dt>
      <dd><%= @order.total_amount.present? ? number_to_currency(@order.total_amount, unit: "¥", precision: 0) : "未計算" %></dd>
    </div>
  </dl>
</section>
